              fill="#DBD5D5"
            />
          </svg>
        </a>
        <p>Jamie Curle</p>
      </div>
    </header>
    <main>
      {@inner_content}
    </main>
    <footer>
      <div class="footer-content">
        <div class="bio">
          <p>
            Jamie Curle is a well rounded human being living and
            operating in Northumberland, UK. He spends his time between
            software, his workshop and restoring ancient woodland. He doesn't
            like it when you bring up the topic of "nearly finished" DIY projects.
          </p>
          <p>
            He would be very interested in working with you, <a href="#">drop him a line</a>.
          </p>
        </div>

