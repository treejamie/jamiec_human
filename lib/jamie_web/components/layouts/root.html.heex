<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="" suffix="  - Jamie Curle">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body
    class={["h-full flex flex-col", assigns[:body_class]]}
    id={assigns[:body_id] || ""}
  >
    <div class="layout">
      <header class="navbar p-8 sm:px-6 lg:px-8 content-width">
        <.theme_toggle />
      </header>
      <main class="p-8 content-width">
        {@inner_content}
      </main>

      <footer class="border-t border-base-content/10  pt-8 pb-8 md:min-h-screen content-width">
        <div class="p-16 about flex flex-col sm:flex-row pt-8 pb-8 ">
          <div class="text w-full sm:w-2/3 text-sm">
            <img
              src="/images/LI.svg"
              alt="asdadas"
              class="block w-[50px] [[data-theme=dark]_&]:hidden rounded-[2px]"
            />
          </div>

          <div class="links w-full sm:w-1/3">
            <p class="mb-4">
              <img
                src="/images/jc_dark.jpg"
                alt="An impromptu photograph of Jamie Curle from 2025 that somehow turned into his main profile picture."
                class="block w-[100px] hidden [[data-theme=dark]_&]:block rounded-[100px]"
              />
              <img
                src="/images/jc_light.jpg"
                alt="An impromptu photograph of Jamie Curle from 2025 that somehow turned into his main profile picture, but with a AI tweaked background colour."
                class="block w-[100px] [[data-theme=dark]_&]:hidden rounded-[100px]"
              />
            </p>
          </div>
        </div>
        <div class="smallprint p-8">
          <p class="text-xs text-base-content/70 uppercase">
            half finished chic & content &copy; {Date.utc_today().year} Jamie Curle.
          </p>
        </div>
      </footer>
    </div>
    <ul class="menu menu-horizontal w-full relative z-10 flex items-center gap-4 px-4 sm:px-6 lg:px-8 justify-end">
      <%= if @current_scope do %>
        <li>
          {@current_scope.user.email}
        </li>
        <li>
          <.link href={~p"/users/log-out"} method="delete">Log out</.link>
        </li>
      <% end %>
    </ul>
  </body>
</html>
